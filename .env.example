# Core
GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
JWT_SECRET=your_jwt_secret_here
SECRET_KEY=your_secret_key_here_for_session_management
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ilm_ai
ENVIRONMENT=development

# Monitoring
SENTRY_DSN=your_sentry_dsn

# Google OAuth (Optional - for Google login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email verification (Gmail SMTP - generate an App Password at
# https://myaccount.google.com/apppasswords). If unset, verification codes
# are printed to the server console instead of emailed (dev fallback).
GMAIL_ADDRESS=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Payment Gateways (Optional - set PAYMENT_TEST_MODE=false for real payments)
PAYMENT_TEST_MODE=true
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_KEY=your_payme_key
CLICK_SERVICE_ID=your_click_service_id
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SECRET_KEY=your_click_secret_key

# ── Content seeding provider (offline batch jobs only, never a request path) ──
# Gemini is the default. To let an OpenAI key carry a batch instead:
#   SEED_PROVIDER=openai
#   OPENAI_API_KEYS=sk-...,sk-...
#   OPENAI_MODEL=gpt-4o-mini
#   OPENAI_BASE_URL=            # optional, for OpenAI-compatible endpoints
# NOTE: if that key is on a data-sharing plan, keep it OUT of the deployed backend's
# environment — see the warning at the top of services/llm_provider.py.
